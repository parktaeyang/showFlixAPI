<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.showflix.api.schedule.mapper.ScheduleSummaryMapper">

    <resultMap id="ScheduleSummaryResult" type="com.showflix.api.schedule.domain.ScheduleSummary">
        <result property="id"      column="id"/>
        <result property="userId"  column="user_id"/>
        <result property="date"    column="date"/>
        <result property="hours"   column="hours"/>
        <result property="remarks" column="remarks"/>
    </resultMap>

    <!-- 월별 전체 조회 (YYYY-MM-01 ~ YYYY-MM-말일) -->
    <select id="findByMonth" resultMap="ScheduleSummaryResult">
        SELECT id, user_id, date, hours, remarks
        FROM schedule_summary
        WHERE date BETWEEN #{start} AND #{end}
        ORDER BY user_id, date
    </select>

    <!-- upsert: 동일 (user_id, date)이면 hours, remarks UPDATE -->
    <insert id="upsert" parameterType="com.showflix.api.schedule.domain.ScheduleSummary">
        INSERT INTO schedule_summary (user_id, date, hours, remarks)
        VALUES (#{userId}, #{date}, #{hours}, #{remarks})
        ON DUPLICATE KEY UPDATE
            hours   = VALUES(hours),
            remarks = VALUES(remarks)
    </insert>

</mapper>
